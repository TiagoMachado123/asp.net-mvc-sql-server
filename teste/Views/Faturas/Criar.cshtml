@model teste.Models.Fatura

<h2>Criar Nova Fatura</h2>

<form asp-action="Criar" method="post">

    <div>
        <label>Nome do Cliente:</label>
        <input type="text" asp-for="NomeCliente" class="form-control" />
    </div>

    <div>
        <label>Valor Total (€):</label>
        <input type="number" step="0.01" asp-for="ValorTotal" class="form-control" />
    </div>

    <br />
    <button type="submit" class="btn btn-success">Guardar Fatura</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>

</form>